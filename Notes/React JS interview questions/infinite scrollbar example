# ✅ 3. Main Example (IMPORTANT)

```javascript
// App.js
import React, { useRef, useEffect } from "react";
import { useInfiniteQuery } from "@tanstack/react-query";
import { FixedSizeList as List } from "react-window";

// API function
const fetchUsers = async ({ pageParam = 1 }) => {
  const res = await fetch(
    `https://jsonplaceholder.typicode.com/posts?_limit=20&_page=${pageParam}`
  );
  return res.json();
};

function App() {
  const {
    data,
    fetchNextPage,
    hasNextPage,
    isFetchingNextPage,
  } = useInfiniteQuery({
    queryKey: ["posts"],
    queryFn: fetchUsers,
    getNextPageParam: (lastPage, pages) => {
      if (lastPage.length === 0) return undefined;
      return pages.length + 1;
    },
  });

  // Flatten pages
  const items = data?.pages.flat() || [];

  // Load more when reaching end
  const loadMoreRef = useRef();

  useEffect(() => {
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && hasNextPage) {
        fetchNextPage();
      }
    });

    if (loadMoreRef.current) {
      observer.observe(loadMoreRef.current);
    }

    return () => observer.disconnect();
  }, [hasNextPage, fetchNextPage]);

  // Row renderer (virtualization)
  const Row = ({ index, style }) => {
    const item = items[index];
    if (!item) return null;

    return (
      <div style={style}>
        ✅ {item.title}
      </div>
    );
  };

  return (
    <div>
      <h2>🚀 Infinite Scroll + Virtualization</h2>

      <List
        height={500}
        itemCount={items.length}
        itemSize={50}
        width={"100%"}
      >
        {Row}
      </List>

      {/* Trigger for loading next page */}
      <div ref={loadMoreRef}>
        {isFetchingNextPage ? "Loading more..." : "Scroll more"}
      </div>
    </div>
  );
}

export default App;
```

