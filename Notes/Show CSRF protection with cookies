# ✅ COMPLETE WORKING EXAMPLE

## 🧩 Backend: Node + Express

### 1️⃣ Install packages

```bash
npm install express jsonwebtoken cookie-parser cors uuid
```

***

## 2️⃣ `server.js`

```js
import express from "express";
import jwt from "jsonwebtoken";
import cookieParser from "cookie-parser";
import cors from "cors";
import { v4 as uuid } from "uuid";

const app = express();
app.use(express.json());
app.use(cookieParser());

app.use(cors({
  origin: "http://localhost:5173",
  credentials: true
}));

const ACCESS_SECRET = "ACCESS_SECRET";
const REFRESH_SECRET = "REFRESH_SECRET";

let refreshTokens = [];
let csrfTokens = {};
```

***

## 3️⃣ Login (sets refresh cookie + CSRF token)

```js
app.post("/login", (req, res) => {
  const accessToken = jwt.sign(
    { userId: 1 },
    ACCESS_SECRET,
    { expiresIn: "15m" }
  );

  const refreshToken = jwt.sign(
    { userId: 1 },
    REFRESH_SECRET,
    { expiresIn: "7d" }
  );

  const csrfToken = uuid();

  refreshTokens.push(refreshToken);
  csrfTokens[refreshToken] = csrfToken;

  // HttpOnly refresh cookie
  res.cookie("refreshToken", refreshToken, {
    httpOnly: true,
    sameSite: "lax",
    secure: false,
    path: "/refresh"
  });

  // CSRF token (readable by JS)
  res.cookie("csrfToken", csrfToken, {
    httpOnly: false,
    sameSite: "lax",
    secure: false
  });

  res.json({ accessToken });
});
```

✅ Refresh token protected\
✅ CSRF token readable by frontend\
✅ Cookies tied to same origin

***

## 4️⃣ CSRF Middleware (THE KEY PART)

```js
function csrfProtection(req, res, next) {
  const refreshToken = req.cookies.refreshToken;
  const csrfHeader = req.headers["x-csrf-token"];

  if (!refreshToken || !csrfHeader) {
    return res.status(403).json({ message: "CSRF missing" });
  }

  const expectedToken = csrfTokens[refreshToken];
  if (csrfHeader !== expectedToken) {
    return res.status(403).json({ message: "CSRF invalid" });
  }

  next();
}
```

✅ Attacker site CANNOT read CSRF token\
✅ Only your frontend can send it

***

## 5️⃣ Refresh Token Endpoint (CSRF‑protected)

```js
app.post("/refresh", csrfProtection, (req, res) => {
  const token = req.cookies.refreshToken;

  if (!refreshTokens.includes(token)) {
    return res.sendStatus(401);
  }

  jwt.verify(token, REFRESH_SECRET, (err, user) => {
    if (err) return res.sendStatus(403);

    const newAccessToken = jwt.sign(
      { userId: user.userId },
      ACCESS_SECRET,
      { expiresIn: "15m" }
    );

    res.json({ accessToken: newAccessToken });
  });
});
```

