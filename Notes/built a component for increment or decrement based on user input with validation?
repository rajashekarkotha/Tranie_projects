# ✅ 5. Bonus (Reusable Component ✅)

```javascript
function CounterInput({ min = 0, max = 10 }) {
  const [value, setValue] = useState(min);

  const increment = () => setValue(v => Math.min(v + 1, max));
  const decrement = () => setValue(v => Math.max(v - 1, min));

  return (
    <div>
      <button onClick={decrement} disabled={value <= min}>-</button>
      <input value={value} readOnly />
      <button onClick={increment} disabled={value >= max}>+</button>
    </div>
  );
}
```

