const arr = [1,2,2,3,4,4,5];

function printDuplicates(arr) {
  let freq = {};
  let duplicates = [];

  arr.forEach(ele => {
    freq[ele] = (freq[ele] || 0) + 1;
  });

  for (let key in freq) {
    if (freq[key] > 1) {
      duplicates.push(Number(key));
    }
  }

  return duplicates;
}

console.log(printDuplicates(arr)); // [2, 4]


