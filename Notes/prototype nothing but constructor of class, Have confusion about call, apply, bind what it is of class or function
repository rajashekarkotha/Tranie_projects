# ✅ 1. Using `call()` with Prototype (Inheritance)

```javascript
function Person(name, age) {
    this.name = name;
    this.age = age;
}

Person.prototype.greet = function () {
    return `Hello, I'm ${this.name}`;
};

function Employee(name, age, role) {
    // Borrow constructor using call()
    Person.call(this, name, age);
    this.role = role;
}

// Inherit prototype
Employee.prototype = Object.create(Person.prototype);
Employee.prototype.constructor = Employee;

const emp = new Employee("Ravi", 28, "Developer");

console.log(emp.greet()); // Hello, I'm Ravi
```

✅ What happened:

*   `call()` used to **reuse constructor**
*   `Employee` gets properties from `Person`
*   Prototype gives access to methods

***

# ✅ 2. Using `apply()` with Prototype

```javascript
function Person(name, age) {
    this.name = name;
    this.age = age;
}

Person.prototype.info = function (city, country) {
    return `${this.name}, ${this.age}, ${city}, ${country}`;
};

const p1 = new Person("Anu", 25);

// Using apply to pass array arguments
console.log(p1.info.apply(p1, ["Hyderabad", "India"]));
```

✅ Output:

    Anu, 25, Hyderabad, India

***

# ✅ 3. Using `bind()` with Prototype Method

```javascript
function Person(name) {
    this.name = name;
}

Person.prototype.sayHi = function () {
    return `Hi ${this.name}`;
};

const p1 = new Person("Rajashekar");

// Bind method
const boundFunc = p1.sayHi.bind(p1);

console.log(boundFunc()); // Hi Rajashekar
```

✅ Key:

*   `bind()` creates a new function
*   Fixes `this` permanently

***

# ✅ 4. Borrowing Prototype Methods (Important)

```javascript
function Animal(name) {
    this.name = name;
}

Animal.prototype.speak = function () {
    return `${this.name} makes noise`;
};

const dog = {
    name: "Bruno"
};

// Borrow method using call
console.log(Animal.prototype.speak.call(dog));
```

👉 Output:

    Bruno makes noise

***

# ✅ 5. call vs apply vs bind with Prototype Method

```javascript
function Person(name) {
    this.name = name;
}

Person.prototype.greet = function (city) {
    return `${this.name} from ${city}`;
};

const user = { name: "Kiran" };

// call
console.log(Person.prototype.greet.call(user, "Delhi"));

// apply
console.log(Person.prototype.greet.apply(user, ["Mumbai"]));

// bind
const fn = Person.prototype.greet.bind(user, "Chennai");
console.log(fn());
```

***

# ✅ 6. Full Mental Model (VERY IMPORTANT)

    Prototype → stores methods

    call/apply/bind → used to control "this"
                     when calling those methods

***

# ✅ 7. Key Interview Insight

👉 Why use them together?

*   `prototype` → reuse methods
*   `call/apply/bind` → reuse methods across **different objects**

***

# ✅ One-Line Explanation

> “Prototype provides method sharing, and call/apply/bind allow those methods to be reused with different objects by controlling `this`.”

