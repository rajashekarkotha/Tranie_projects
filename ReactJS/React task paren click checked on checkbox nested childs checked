import React, { useEffect, useState } from "react";
import "./style.css";

export default function App() {
  const [data, setData] = useState([]);
  const [parentChecked, setParentChecked] = useState(false);
  const [childChecked, setChildChecked] = useState({});

  useEffect(() => {
    fetch("https://jsonplaceholder.typicode.com/todos?_limit=5")
      .then((res) => res.json())
      .then((data) => {
        setData(data);
        // initialize child checkboxes as false
        const initialState = {};
        data.forEach((item) => {
          initialState[item.id] = false;
        });
        setChildChecked(initialState);
      });
  }, []);

  const handleParentChange = (e) => {
    const checked = e.target.checked;
    setParentChecked(checked);

    // update all children when parent changes
    const updatedChildren = {};
    data.forEach((item) => {
      updatedChildren[item.id] = checked;
    });
    setChildChecked(updatedChildren);
  };

  const handleChildChange = (id) => {
    setChildChecked((prev) => ({
      ...prev,
      [id]: !prev[id],
    }));
  };

  return (
    <div>
      <h1>Hello StackBlitz!</h1>
      <div>
        <input
          type="checkbox"
          checked={parentChecked}
          onChange={handleParentChange}
        />{" "}
        <h5>Parent</h5>
      </div>
      {data.map((ele) => (
        <Child
          key={ele.id}
          childData={ele}
          checked={childChecked[ele.id] || false}
          onChange={() => handleChildChange(ele.id)}
        />
      ))}
    </div>
  );
}

const Child = ({ childData, checked, onChange }) => {
  return (
    <div>
      <li>
        <input type="checkbox" checked={checked} onChange={onChange} />{" "}
        {childData.title}
      </li>
    </div>
  );
};
